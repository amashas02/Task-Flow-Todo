<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor"
    android:clickable="true"
    android:focusable="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/btnBackEdit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_arrow_back"
                android:padding="8dp"
                app:tint="@color/textColorDark"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Edit Profile"
                android:textSize="22sp"
                android:textColor="@color/textColorDark"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Avatar Selection -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose Avatar"
            android:textColor="@color/textColorDark"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAvatarMale"
                android:layout_width="100dp"
                android:layout_height="100dp"
                app:cardCornerRadius="50dp"
                app:cardElevation="0dp"
                app:strokeWidth="3dp"
                app:strokeColor="@color/inputBorder"
                app:cardBackgroundColor="@color/secondaryBackground"
                android:layout_marginEnd="24dp">

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_avatar_male"/>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAvatarFemale"
                android:layout_width="100dp"
                android:layout_height="100dp"
                app:cardCornerRadius="50dp"
                app:cardElevation="0dp"
                app:strokeWidth="3dp"
                app:strokeColor="@color/inputBorder"
                app:cardBackgroundColor="@color/secondaryBackground">

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_avatar_female"/>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- First Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="First Name"
            android:textColor="@color/textColorDark"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etFirstName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input_outline"
            android:hint="Enter first name"
            android:inputType="textPersonName"
            android:padding="12dp"
            android:textColor="@color/textColorDark"
            android:textColorHint="@color/textColorMuted"
            android:textSize="14sp" />

        <!-- Last Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"
            android:text="Last Name"
            android:textColor="@color/textColorDark"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etLastName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input_outline"
            android:hint="Enter last name"
            android:inputType="textPersonName"
            android:padding="12dp"
            android:textColor="@color/textColorDark"
            android:textColorHint="@color/textColorMuted"
            android:textSize="14sp" />

        <!-- Date of Birth -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"
            android:text="Date of Birth"
            android:textColor="@color/textColorDark"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etDateOfBirth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input_outline"
            android:hint="DD/MM/YYYY"
            android:inputType="date"
            android:padding="12dp"
            android:focusable="false"
            android:clickable="true"
            android:textColor="@color/textColorDark"
            android:textColorHint="@color/textColorMuted"
            android:textSize="14sp" />

        <!-- Gender -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"
            android:text="Gender"
            android:textColor="@color/textColorDark"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGenderMale"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Male"
                android:textAllCaps="false"
                android:textSize="14sp"
                app:cornerRadius="8dp"
                app:strokeColor="@color/inputBorder"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGenderFemale"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Female"
                android:textAllCaps="false"
                android:textSize="14sp"
                app:cornerRadius="8dp"
                app:strokeColor="@color/inputBorder"/>
        </LinearLayout>

        <!-- Save Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveProfile"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="32dp"
            android:text="Save Profile"
            android:textAllCaps="false"
            android:textColor="@color/backgroundColor"
            android:textSize="15sp"
            app:backgroundTint="@color/primaryColor"
            app:cornerRadius="8dp" />

    </LinearLayout>
</ScrollView>
